# Django
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend,frontend
DJANGO_SETTINGS_MODULE=config.settings.development

# Database
POSTGRES_DB=psc_drfms
POSTGRES_USER=psc_user
POSTGRES_PASSWORD=psc_secure_password
DATABASE_URL=postgresql://psc_user:psc_secure_password@db:5432/psc_drfms

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=psc-drfms-documents
MINIO_USE_HTTPS=False

# Anthropic API (Phase 1-3 interim exception - OPSC Management approval required)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Email (Django SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@psc.gov.vu
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=PSC-DRFMS <noreply@psc.gov.vu>

# Email ingestion (IMAP - email-to-record feature)
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=records@psc.gov.vu
IMAP_PASSWORD=your-imap-password
IMAP_MAILBOX=INBOX

# SAML / SSO (Phase 3 - Government Active Directory)
SAML_ENABLED=False
SAML_SP_ENTITY_ID=https://drfms.psc.gov.vu
SAML_IDP_METADATA_URL=https://ad.gov.vu/FederationMetadata/2007-06/FederationMetadata.xml

# 2FA
OTP_TOTP_ISSUER=PSC-DRFMS

# Security
SESSION_COOKIE_AGE=28800
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8000

# Superuser (created on first run)
DJANGO_SUPERUSER_EMAIL=admin@psc.gov.vu
DJANGO_SUPERUSER_PASSWORD=Admin@123!
DJANGO_SUPERUSER_USERNAME=admin
